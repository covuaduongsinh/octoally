{
  "name": "octoally-desktop",
  "version": "1.0.87",
  "description": "OctoAlly Desktop App",
  "author": {
    "name": "AI Genius Automations",
    "email": "support@aigeniusautomations.com"
  },
  "homepage": "https://github.com/ai-genius-automations/octoally",
  "license": "Apache-2.0 WITH Commons-Clause",
  "main": "dist/main.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start": "npm run build && electron . --no-sandbox",
    "start:dev": "npm run build && ELECTRON_ENABLE_LOGGING=1 electron . --no-sandbox",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.aigenius.octoally",
    "productName": "OctoAlly",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "icons/**",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "icons",
      "executableName": "octoally-desktop"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "icons/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "dmg-license": "^1.0.11"
  },
  "overrides": {
    "@xmldom/xmldom": "~0.8.13",
    "ip-address": ">=10.1.1"
  }
}
