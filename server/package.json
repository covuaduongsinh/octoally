    "nanoid": "^5.0.0",
    "node-pty-prebuilt-multiarch": "^0.10.1-pre.5",
    "pino-pretty": "^13.1.3",
    "strip-ansi": "^7.1.0",
    "superjson": "^2.2.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
